# Copy this file to .env and adjust values as needed.

# ── CIS study number range to probe ───────────────────────────────────────────
# CIS studies are numbered sequentially. Adjust to narrow/widen the scan.
# Default: probe 2000–3600 (covers ~20 years of studies)
CIS_STUDY_START=2000
CIS_STUDY_END=3600

# ── Storage budget ─────────────────────────────────────────────────────────────
STORAGE_BUDGET_MB=2048
MAX_FILE_SIZE_MB=100

# ── Download scope (qda-only | text | all) ─────────────────────────────────────
DOWNLOAD_SCOPE=qda-only
