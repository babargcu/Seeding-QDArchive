# Copy this file to .env and fill in any tokens you have.
# All tokens are optional but increase rate limits and prevent 403 errors.

# ── API tokens ─────────────────────────────────────────────────────────────────

# Zenodo — https://zenodo.org → Account Settings → Applications → Personal access tokens
ZENODO_TOKEN=

# Harvard Dataverse (also used for Harvard Murray Archive)
# https://dataverse.harvard.edu → Account Information → API Token → Create Token
HARVARD_DATAVERSE_TOKEN=

# DataverseNO — https://dataverse.no → Account Information → API Token
DATAVERSENO_TOKEN=

# QDR Syracuse — https://data.qdr.syr.edu → Account Information → API Token
QDR_TOKEN=

# OSF — https://osf.io → Settings → Personal access tokens
OSF_TOKEN=

# Figshare — https://figshare.com → My Account → Applications → Create token
FIGSHARE_TOKEN=

# ── Storage budget ─────────────────────────────────────────────────────────────
STORAGE_BUDGET_MB=2048
MAX_FILE_SIZE_MB=100

# ── Download scope (qda-only | text | all) ─────────────────────────────────────
DOWNLOAD_SCOPE=qda-only
